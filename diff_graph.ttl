@prefix ns1: <http://example.org/ontology#> .

ns1:process1 a ns1:Experiment ;
    ns1:hasExperimentSetup ns1:processStep1 ;
    ns1:hasSample ns1:input1 .

ns1:process2 a ns1:Experiment ;
    ns1:hasExperimentSetup ns1:processStep2 ;
    ns1:hasSample ns1:input2 .

ns1:process3 a ns1:Experiment ;
    ns1:hasExperimentSetup ns1:processStep3 ;
    ns1:hasSample ns1:input3 .

ns1:process4 a ns1:Experiment ;
    ns1:hasExperimentSetup ns1:processStep4 ;
    ns1:hasSample ns1:input4 .

ns1:input1 a ns1:Sample ;
    ns1:hasConcentrations ns1:inputSettings1 .

ns1:input2 a ns1:Sample ;
    ns1:hasConcentrations ns1:inputSettings2 .

ns1:input3 a ns1:Sample ;
    ns1:hasConcentrations ns1:inputSettings3 .

ns1:input4 a ns1:Sample ;
    ns1:hasConcentrations ns1:inputSettings4 .

ns1:processStep1 a ns1:ExperimentSetup ;
    ns1:performedWith ns1:inputSettings1 .

ns1:processStep2 a ns1:ExperimentSetup ;
    ns1:performedWith ns1:inputSettings2 .

ns1:processStep3 a ns1:ExperimentSetup ;
    ns1:performedWith ns1:inputSettings3 .

ns1:processStep4 a ns1:ExperimentSetup ;
    ns1:performedWith ns1:inputSettings4 .

ns1:inputSettings1 a ns1:Parameters .

ns1:inputSettings2 a ns1:Parameters .

ns1:inputSettings3 a ns1:Parameters .

ns1:inputSettings4 a ns1:Parameters .

